---
import { t, getLanguage } from '@acacia/common/i18n';

let currentLanguage = getLanguage(),
    languages = [
        { locale: 'en', name: 'English' },
        { locale: 'de', name: 'Deutsch' },
        { locale: 'es', name: 'Español' },
        { locale: 'fr', name: 'Français' },
        { locale: 'pt', name: 'Português' },
        { locale: 'ro', name: 'Română' },
        { locale: 'ru', name: 'Русский' },
        { locale: 'tl', name: 'Tagalog' }
    ];
---

<div id="intro">
    <section id="parchment" class="load-character slice-menu-fancy">
        <article id="load-character">
            <h1 class="title-decoration">{t('game:NAME')}</h1>

            <form onsubmit={'return false'}>
                <input
                    type="text"
                    id="login-name-input"
                    class="stroke slice-input"
                    name="player-name"
                    placeholder={t('game:INTRO.COMMON.USERNAME')}
                    aria-label={t('game:INTRO.COMMON.USERNAME')}
                    maxlength="32"
                    autocomplete="off"
                />
                <input
                    type="password"
                    id="login-password-input"
                    class="stroke slice-input"
                    name="player-password"
                    placeholder={t('game:INTRO.COMMON.PASSWORD')}
                    aria-label={t('game:INTRO.COMMON.PASSWORD')}
                    maxlength="64"
                    autocomplete="off"
                />

                <div class="validation-summary"></div>

                <div class="button-row">
                    <label id="remember-me" class="check">
                        <input
                            type="checkbox"
                            aria-labelledby="remember-me-text"
                            aria-label={t('game:INTRO.LOGIN.REMEMBER_ME')}
                        />
                        <span class="checkmark"></span>

                        <span id="remember-me-text">{t('game:INTRO.LOGIN.REMEMBER_ME')}</span>
                    </label>
                    <label id="guest" class="check">
                        <input
                            type="checkbox"
                            aria-labelledby="guest-text"
                            aria-label={t('game:INTRO.LOGIN.GUEST')}
                        />
                        <span class="checkmark"></span>

                        <span id="guest-text">{t('game:INTRO.LOGIN.GUEST')}</span>
                    </label>
                </div>

                <div class="button-row">
                    <button
                        title={t('game:INTRO.LOGIN.LOGIN')}
                        aria-label={t('game:INTRO.LOGIN.LOGIN')}
                        type="submit"
                        id="login"
                        class="stroke slice-button"
                        disabled
                    >
                        {t('game:INTRO.LOGIN.LOGIN')}
                    </button>
                    <button
                        title={t('game:INTRO.LOGIN.NEW_ACCOUNT')}
                        aria-label={t('game:INTRO.LOGIN.NEW_ACCOUNT')}
                        type="button"
                        id="new-account"
                        class="stroke slice-button"
                    >
                        {t('game:INTRO.LOGIN.NEW_ACCOUNT')}
                    </button>
                </div>
            </form>
        </article>

        <article id="create-character">
            <h1 class="title-decoration">{t('game:INTRO.REGISTER.TITLE')}</h1>

            <form onsubmit={'return false'}>
                <input
                    type="text"
                    id="register-name-input"
                    class="stroke slice-input"
                    name="player-name"
                    placeholder={t('game:INTRO.COMMON.USERNAME')}
                    aria-label={t('game:INTRO.COMMON.USERNAME')}
                    maxlength="32"
                    autocomplete="off"
                />
                <input
                    type="password"
                    id="register-password-input"
                    class="stroke slice-input"
                    name="player-password"
                    placeholder={t('game:INTRO.COMMON.PASSWORD')}
                    aria-label={t('game:INTRO.COMMON.PASSWORD')}
                    maxlength="64"
                    autocomplete="off"
                />
                <input
                    type="password"
                    id="register-password-confirmation-input"
                    class="stroke slice-input"
                    name="player-password2"
                    placeholder={t('game:INTRO.REGISTER.CONFIRM_PASSWORD')}
                    aria-label={t('game:INTRO.REGISTER.CONFIRM_PASSWORD')}
                    maxlength="64"
                    autocomplete="off"
                />
                <input
                    type="email"
                    id="register-email-input"
                    class="stroke slice-input"
                    name="player-email"
                    placeholder={t('game:INTRO.COMMON.EMAIL_ADDRESS')}
                    aria-label={t('game:INTRO.COMMON.EMAIL_ADDRESS')}
                    maxlength="64"
                    autocomplete="off"
                />

                <div class="validation-summary"></div>

                <div class="button-row">
                    <button
                        title={t('game:INTRO.COMMON.CANCEL')}
                        aria-label={t('game:INTRO.COMMON.CANCEL')}
                        type="button"
                        id="cancel-register"
                        class="stroke slice-button"
                    >
                        {t('game:INTRO.COMMON.CANCEL')}
                    </button>
                    <button
                        title={t('game:INTRO.COMMON.PLAY')}
                        aria-label={t('game:INTRO.COMMON.PLAY')}
                        type="submit"
                        id="play"
                        class="stroke slice-button"
                    >
                        {t('game:INTRO.COMMON.PLAY')}
                    </button>
                </div>
            </form>
        </article>

        <article id="reset-password">
            <h1>
                <span class="left-ornament"></span>
                {t('game:INTRO.RESET_PASSWORD.TITLE')}
                <span class="right-ornament"></span>
            </h1>

            <form onsubmit={'return false'}>
                <input
                    type="text"
                    id="email-reset-input"
                    class="stroke slice-input"
                    name="player-email"
                    placeholder={t('game:INTRO.COMMON.EMAIL_ADDRESS')}
                    aria-label={t('game:INTRO.COMMON.EMAIL_ADDRESS')}
                    maxlength="32"
                    autocomplete="off"
                />

                <div class="validation-summary"></div>

                <div class="button-row">
                    <button
                        title={t('game:INTRO.COMMON.CANCEL')}
                        aria-label={t('game:INTRO.COMMON.CANCEL')}
                        type="button"
                        id="cancel-forget"
                        class="stroke slice-button"
                    >
                        {t('game:INTRO.COMMON.CANCEL')}
                    </button>
                    <button
                        title={t('game:INTRO.RESET_PASSWORD.SUBMIT')}
                        aria-label={t('game:INTRO.RESET_PASSWORD.SUBMIT')}
                        type="submit"
                        id="continue-forget"
                        class="stroke slice-button"
                    >
                        {t('game:INTRO.COMMON.CONTINUE')}
                    </button>
                </div>
            </form>
        </article>

        <article id="world-select">
            <h1>
                <span class="left-ornament"></span>
                {t('game:INTRO.WORLD_SELECT.TITLE')}
                <span class="right-ornament"></span>
            </h1>

            <form onsubmit={'return false'}>
                <ol id="worlds"></ol>

                <div class="button-row">
                    <button
                        title={t('game:INTRO.COMMON.CANCEL')}
                        aria-label={t('game:INTRO.COMMON.CANCEL')}
                        type="button"
                        id="cancel-worlds"
                        class="stroke slice-button"
                    >
                        {t('game:INTRO.COMMON.CANCEL')}
                    </button>
                    <button
                        title={t('game:INTRO.COMMON.CONTINUE')}
                        aria-label={t('game:INTRO.COMMON.CONTINUE')}
                        type="submit"
                        id="continue-worlds"
                        class="stroke slice-button"
                    >
                        {t('game:INTRO.COMMON.CONTINUE')}
                    </button>
                </div>
            </form>
        </article>

        <article id="credits">
            <h1 class="title-decoration">{t('game:INTRO.CREDITS.TITLE')}</h1>

            <p>
                <br />
                {t('game:INTRO.CREDITS.SPECIAL_THANKS')}{' '}
                <a
                    rel="noopener noreferrer"
                    class="clickable"
                    target="_blank"
                    href="https://www.littleworkshop.fr/">Little Workshop</a
                >{' '}
                {t('game:INTRO.CREDITS.FOR_PIXEL_ART')}
                <br />
                <br />
                {t('game:INTRO.CREDITS.AND_ASKY_TEAM')}
                <br />
                <br />
                {t('game:INTRO.CREDITS.MORE_PIXEL_ASSETS_BY')}{' '}
                <a
                    rel="noopener noreferrer"
                    class="clickable"
                    target="_blank"
                    href="https://opengameart.org/users/buch">Buch</a
                >,
                <a
                    rel="noopener noreferrer"
                    class="clickable"
                    target="_blank"
                    href="https://shikashiassets.itch.io/shikashis-fantasy-icons-pack">Shikashi</a
                >,
                <a
                    rel="noopener noreferrer"
                    class="clickable"
                    target="_blank"
                    href="https://opengameart.org/content/kyrises-free-16x16-rpg-icon-pack"
                    >Kyrise</a
                >,
                <a
                    rel="noopener noreferrer"
                    class="clickable"
                    target="_blank"
                    href="https://game-icons.net">Game-Icons.net</a
                >, & Boo
                <br />
                <br />
                {t('game:INTRO.CREDITS.MUSIC_BY')}{' '}
                <a
                    rel="noopener noreferrer"
                    class="clickable"
                    target="_blank"
                    href="https://soundcloud.com/gyrowolf">Terrel O'Brien</a
                >,
                <a
                    rel="noopener noreferrer"
                    class="clickable"
                    target="_blank"
                    href="https://blog.dayjo.org">Joel Day</a
                >,
                <a
                    rel="noopener noreferrer"
                    class="clickable"
                    target="_blank"
                    href="https://www.dantilden.com">Dan Tilden</a
                >, &
                <a
                    rel="noopener noreferrer"
                    target="_blank"
                    class="clickable"
                    href="https://soundcloud.com/aaron-anderson-11">Aaron Krogh</a
                >
            </p>

            <div class="close-about">
                <span>{t('game:INTRO.COMMON.CLICK_ANYWHERE_TO_CLOSE')}</span>
            </div>
        </article>

        <article id="about">
            <h1 class="title-decoration">{t('game:INTRO.ABOUT.TITLE')}</h1>

            <p>
                {t('game:INTRO.ABOUT.DESCRIPTION')}{' '}
                {t('game:INTRO.ABOUT.SOURCE_CODE_ON')}{' '}
                <a target="_blank" href="https://github.com/Kaetram/Kaetram-Open"
                    >{t('game:INTRO.ABOUT.GITHUB_REPOSITORY')}</a
                >. {t('game:INTRO.ABOUT.JOIN_DISCORD')}{' '}
                <a target="_blank" href="https://discord.gg/MmbGAaw"
                    >{t('game:INTRO.ABOUT.DISCORD_SERVER')}</a
                >.
            </p>

            <div class="close-about">
                <span>{t('game:INTRO.COMMON.CLICK_ANYWHERE_TO_CLOSE')}</span>
            </div>
        </article>

        <article id="git">{t('game:INTRO.GIT.PLACEHOLDER')}</article>

        <article id="death">
            <h1>{t('game:INTRO.DEATH.TITLE')}</h1>
            <button
                title={t('game:INTRO.DEATH.RESPAWN')}
                id="respawn"
                aria-label={t('game:INTRO.DEATH.RESPAWN')}
                class="stroke slice-button">{t('game:INTRO.DEATH.RESPAWN')}</button
            >
        </article>

        <span class="loader" hidden>
            {t('game:INTRO.LOADER.CONNECTING')}<span class="loader-dot">.</span><span
                class="loader-dot">.</span><span class="loader-dot">.</span>
        </span>
    </section>

    <select id="lang-select" oninput={'location = "/" + this.value + "/"'}>
        {
            languages.map(({ locale, name }) => (
                <option value={locale} selected={locale === currentLanguage}>
                    {name}
                </option>
            ))
        }
    </select>

    <button id="world-select-button" class="slice-button" hidden>
        <strong class="stroke"></strong>
        <span class="stroke"></span>
    </button>

    <span id="game-version" class="version"></span>

    <footer>
        <div id="about-link" class="clickable">
            <span id="toggle-about">{t('game:INTRO.ABOUT.TITLE')}</span>
        </div>
        <span>&ndash;</span>
        <div id="credits-link" class="clickable">
            <span id="toggle-credits">{t('game:INTRO.CREDITS.TITLE')}</span>
        </div>
        <span>&ndash;</span>
        <div id="discord-link" class="clickable">
            <a class="footer-button" target="_blank" href="https://discord.gg/MmbGAaw">
                <span>{t('game:INTRO.FOOTER.DISCORD')}</span>
            </a>
        </div>
        <span>&ndash;</span>
        <div class="clickable">
            <a
                class="footer-button"
                target="_blank"
                href="https://www.patreon.com/bePatron?u=29287394"
            >
                <span>{t('game:INTRO.FOOTER.PATREON')}</span>
            </a>
        </div>
        <span>&ndash;</span>
        <div id="privacy" class="clickable">
            <a class="footer-button" href="/privacy/">
                <span>{t('game:INTRO.FOOTER.PRIVACY')}</span>
            </a>
        </div>
        <span>&ndash;</span>
        <div id="reset" class="clickable">
            <span id="toggle-reset-password">{t('game:INTRO.RESET_PASSWORD.TITLE')}</span>
        </div>
    </footer>
</div>
